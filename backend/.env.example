# Database (SQLite default matches repo layout when cwd is backend/)
DATABASE_URL=sqlite:///./app/chalk.db

# SQL echo for debugging
# SQL_ECHO=true

# Canonical public URL of this API (optional; used for CORS if CORS_ORIGINS unset)
# BASE_URL=https://api.your-domain.com

# Comma-separated allowed browser origins (overrides BASE_URL for CORS)
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Interswitch (payment verification)
# ISW_MERCHANT_CODE=
# ISW_PAY_ITEM_ID=
# ISW_CLIENT_ID=
# ISW_SECRET=
# ISW_API_BASE=https://qa.interswitchng.com

# JWT / auth (required; matches app/security.py)
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
